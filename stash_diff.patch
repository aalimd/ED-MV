-// ─── WAVEFORM RENDERER ───────────────────────────────
+// ─── WAVEFORM RENDERER (ANIMATED SIMULATION) ─────────
 // Coordinate system: viewBox 0 0 400 200
 // Pressure region: y=15 (top, peak) ↔ y=95 (bottom)
 // Divider:         y=100
 // Flow region:     y=105 (top, peak inspiratory) ↔ y=195 (bottom, peak expiratory)
 //                  Flow baseline (0 flow) = y=155
-//
-// Each scenario draws TWO full breath cycles to clearly show repeating physiology.
-// One cycle spans 190 SVG units; with I:E ≈ 1:2 → inspiration ≈ 63u, expiration ≈ 127u.
+
+const SIM_PHYSIOLOGY = {
+  normal: { compliance: 50, resistance: 5 },
+  ards: { compliance: 15, resistance: 5 },
+  obstructive: { compliance: 60, resistance: 35 },
+  restrictive: { compliance: 25, resistance: 10 }
+};
+
+let simState = {
+  active: false,
+  mode: 'AC-VC',
+  physiology: 'normal',
+  vt: 450,
+  pinsp: 15,
+  rr: 14,
+  peep: 5,
+  fio2: 40,
+  flow: 60,
+  _lastPbw: null,
+  _lastScenario: null
+};
+
+function generateDynamicSimulationPaths() {
+  if (!simState.active) return;
+
+  const physObj = SIM_PHYSIOLOGY[simState.physiology] || SIM_PHYSIOLOGY.normal;
+  const compliance = Math.max(5, physObj.compliance);
+  const resistance = Math.max(1, physObj.resistance);
+  const tau = (compliance * resistance) / 1000; // in seconds
+
+  const rr = simState.rr;
+  const peep = simState.peep;
+  const mode = simState.mode;
+  const vt = simState.vt;
+  const pinsp = simState.pinsp;
+  const flow = simState.flow;
+
+  const tTot = 60 / rr;
+  const tI = tTot / 3;
+  const tE = tTot - tI;
+
+  let pDrive = 0;
+  let finalVte = 0;
+
+  if (mode === 'AC-VC') {
+    const qLps = flow / 60;
+    finalVte = Math.round(Math.min(vt, qLps * tI * 1000));
+    pDrive = finalVte / compliance;
+  } else {
+    pDrive = pinsp * (1 - Math.exp(-tI / tau));
+    finalVte = Math.round(pDrive * compliance);
+  }
+
+  const expFactor = Math.exp(-tE / tau);
+  let autoPeep = (pDrive * expFactor) / Math.max(0.01, 1 - expFactor);
+  autoPeep = Math.min(20, Math.max(0, autoPeep)); // clamp to [0, 20]
+
+  // Calculate PIP
+  let rawPip = peep + autoPeep;
+  if (mode === 'AC-VC') {
+    const qLps = flow / 60;
+    rawPip = peep + autoPeep + pDrive + (qLps * resistance);
+  } else {
+    rawPip = peep + pinsp;
+  }
+
+  const targetP = new Array(400).fill(85);
+  const targetF = new Array(400).fill(155);
+
+  const tauCircuit = 0.08;
+  const tauRise = 0.08;
+
+  for (let x = 10; x <= 390; x++) {
+    const t = ((x - 10) / 380) * 4.0;
+    const tCycle = t % tTot;
+
+    let pVal = peep;
+    let fVal = 0;
+
+    if (mode === 'AC-VC') {
+      const qLps = flow / 60;
+      const tInspFlow = Math.min(tI, finalVte / (qLps * 1000));
+      
+      if (tCycle < tInspFlow) {
+        const vol = qLps * tCycle * 1000;
+        pVal = peep + autoPeep + (vol / compliance) + (qLps * resistance);
+        fVal = flow;
+      } else if (tCycle < tI) {
+        pVal = peep + autoPeep + pDrive;
+        fVal = 0;
+      } else {
+        const tExp = tCycle - tI;
+        pVal = peep + (rawPip - peep) * Math.exp(-tExp / tauCircuit);
+        fVal = -((autoPeep + pDrive) / resistance) * Math.exp(-tExp / tau) * 60;
+      }
+    } else {
+      // AC-PC
+      const activeDrive = Math.max(0, pinsp - autoPeep);
+      if (tCycle < tI) {
+        pVal = peep + autoPeep + activeDrive * (1 - Math.exp(-tCycle / tauRise));
+        fVal = (activeDrive / resistance) * Math.exp(-tCycle / tau) * 60;
+      } else {
+        const tExp = tCycle - tI;
+        pVal = peep + (rawPip - peep) * Math.exp(-tExp / tauCircuit);
+        fVal = -((autoPeep + pDrive) / resistance) * Math.exp(-tExp / tau) * 60;
+      }
+    }
+
+    const yP = 85 - (pVal / 60) * 70;
+    targetP[x] = Math.max(15, Math.min(95, yP));
+
+    const yF = 155 - (fVal / 120) * 40;
+    targetF[x] = Math.max(105, Math.min(195, yF));
+  }
+
+  for (let x = 0; x < 10; x++) {
+    targetP[x] = targetP[10];
+    targetF[x] = targetF[10];
+  }
+  for (let x = 391; x < 400; x++) {
+    targetP[x] = targetP[390];
+    targetF[x] = targetF[390];
+  }
+
+  ventAnim.targetPressureY = targetP;
+  ventAnim.targetFlowY = targetF;
+}
+
+function adjustSimParam(param, delta) {
+  if (!simState.active) return;
+  
+  if (param === 'vt') {
+    simState.vt = Math.max(200, Math.min(800, simState.vt + delta));
+  } else if (param === 'pinsp') {
+    simState.pinsp = Math.max(5, Math.min(40, simState.pinsp + delta));
+  } else if (param === 'rr') {
+    simState.rr = Math.max(8, Math.min(40, simState.rr + delta));
+  } else if (param === 'peep') {
+    simState.peep = Math.max(0, Math.min(24, simState.peep + delta));
+  } else if (param === 'fio2') {
+    simState.fio2 = Math.max(21, Math.min(100, simState.fio2 + delta));
+  } else if (param === 'flow') {
+    simState.flow = Math.max(30, Math.min(100, simState.flow + delta));
+  }
+
+  generateDynamicSimulationPaths();
+  updateLiveDigits(true);
+}
+
+function toggleSimMode() {
+  if (!simState.active) return;
+  simState.mode = simState.mode === 'AC-VC' ? 'AC-PC' : 'AC-VC';
+  ventAnim.activeType = 'simulator';
+  generateDynamicSimulationPaths();
+  updateLiveDigits(true);
+}
