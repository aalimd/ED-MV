+function updateLiveDigits(force = false) {
+  const scenarioId = Store.get('scenario') || 'healthy';
+  const param = CLINICAL_PARAMS[scenarioId] || CLINICAL_PARAMS.healthy;
+  const pbw = Store.get('pbw');
+
+  const pplatContainer = document.getElementById('ventPplatContainer');
+  const pplatValEl = document.getElementById('ventPplat');
+  const autoPeepContainer = document.getElementById('ventAutoPeepContainer');
+  const autoPeepValEl = document.getElementById('ventAutoPeep');
+
+  if (simState.active) {
+    const physObj = SIM_PHYSIOLOGY[simState.physiology] || SIM_PHYSIOLOGY.normal;
+    const compliance = Math.max(5, physObj.compliance);
+    const resistance = Math.max(1, physObj.resistance);
+    const tau = (compliance * resistance) / 1000; // in seconds
+
+    const rr = simState.rr;
+    const peep = simState.peep;
+    const mode = simState.mode;
+    const vt = simState.vt;
+    const pinsp = simState.pinsp;
+    const flow = simState.flow;
+
+    const tTot = 60 / rr;
+    const tI = tTot / 3;
+    const tE = tTot - tI;
+
+    let pDrive = 0;
+    let finalVte = 0;
+
+    if (mode === 'AC-VC') {
+      const qLps = flow / 60;
+      finalVte = Math.round(Math.min(vt, qLps * tI * 1000));
+      pDrive = finalVte / compliance;
+    } else {
+      pDrive = pinsp * (1 - Math.exp(-tI / tau));
+      finalVte = Math.round(pDrive * compliance);
+    }
+
+    const expFactor = Math.exp(-tE / tau);
+    let autoPeep = (pDrive * expFactor) / Math.max(0.01, 1 - expFactor);
+    autoPeep = Math.min(20, Math.max(0, autoPeep)); // clamp to [0, 20]
+
+    // Calculate PIP
+    let rawPip = peep + autoPeep;
+    if (mode === 'AC-VC') {
+      const qLps = flow / 60;
+      rawPip = peep + autoPeep + pDrive + (qLps * resistance);
+    } else {
+      rawPip = peep + pinsp;
+    }
+
+    const rawPplat = peep + autoPeep + pDrive;
+
+    // Add noise/wiggle
+    const noiseP = (Math.random() - 0.5) * 0.8;
+    const noiseV = Math.round((Math.random() - 0.5) * 8);
+    const noisePplat = (Math.random() - 0.5) * 0.4;
+    const noiseAuto = (Math.random() - 0.5) * 0.2;
+
+    const finalPip = Math.max(0, Math.round(rawPip + noiseP));
+    const finalVteWiggled = Math.max(0, Math.round(finalVte + noiseV));
+    const finalPplat = Math.max(0, Math.round(rawPplat + noisePplat));
+    const finalAutoPeep = Math.max(0, Math.round(autoPeep + noiseAuto));
+    const finalPeep = Math.max(0, Math.round(peep + (Math.random() - 0.5) * 0.4));
+    const finalRr = rr;
+    const finalFiO2 = simState.fio2;
+    const finalMve = parseFloat(((finalVteWiggled * finalRr) / 1000).toFixed(1));
+
+    // Determine Alarm
+    let alarmText = 'NORMAL OPERATION';
+    let alarmState = 'normal';
+    if (finalPip >= 35) {
+      alarmText = '⚠️ HIGH AIRWAY PRESSURE';
+      alarmState = 'warning';
+    } else if (finalVteWiggled < 300) {
+      alarmText = '⚠️ LOW TIDAL VOLUME';
+      alarmState = 'warning';
+    } else if (finalMve < 4.0) {
+      alarmText = '⚠️ LOW MINUTE VENTILATION';
+      alarmState = 'warning';
+    }
+
+    // Write values to elements
+    const pipEl = document.getElementById('ventPip');
+    const peepEl = document.getElementById('ventPeep');
+    const vteEl = document.getElementById('ventVte');
+    const mveEl = document.getElementById('ventMve');
+    const rrEl = document.getElementById('ventRr');
+    const fio2El = document.getElementById('ventFiO2');
+    const alarmEl = document.getElementById('ventAlarm');
+    const modeEl = document.getElementById('ventMode');
+
+    if (pipEl) pipEl.textContent = finalPip;
+    if (peepEl) peepEl.textContent = finalPeep;
+    if (vteEl) vteEl.textContent = finalVteWiggled;
+    if (mveEl) mveEl.textContent = finalMve.toFixed(1);
+    if (rrEl) rrEl.textContent = finalRr;
+    if (fio2El) fio2El.textContent = finalFiO2;
+    if (modeEl) modeEl.textContent = mode;
+
+    if (pplatContainer) pplatContainer.style.display = 'inline';
+    if (pplatValEl) pplatValEl.textContent = finalPplat;
+    if (autoPeepContainer) autoPeepContainer.style.display = 'inline';
+    if (autoPeepValEl) autoPeepValEl.textContent = finalAutoPeep;
+
+    if (alarmEl) {
+      alarmEl.textContent = alarmText;
+      if (alarmState === 'warning') {
+        alarmEl.className = 'vent-alarm warning';
+      } else {
+        alarmEl.className = 'vent-alarm normal';
+      }
+    }
+
+    // Always render interactive dials in simulator mode if forced or mode/values changed
+    if (force || ventAnim._lastDialScenario !== 'simulator' || ventAnim._lastDialVt !== vt || ventAnim._lastDialMode !== mode) {
+      renderInteractiveDials();
+      ventAnim._lastDialScenario = 'simulator';
+      ventAnim._lastDialVt = vt;
+      ventAnim._lastDialMode = mode;
+    }
+    return;
+  }
+
+  if (pplatContainer) pplatContainer.style.display = 'none';
+  if (autoPeepContainer) autoPeepContainer.style.display = 'none';
+
+  let baseVt = param.defaultVt;
+  if (param.vtPerKg && pbw) {
+    baseVt = Math.round(pbw * param.vtPerKg);
+  }
+
+  // Wiggle PIP, Vte
+  const noiseP = (Math.random() - 0.5) * 0.8;
+  const noiseV = Math.round((Math.random() - 0.5) * 8);
+
+  const finalPip = Math.round(param.pip + noiseP);
+  const finalVte = Math.round(baseVt + noiseV);
+  const finalPeep = param.peep;
+  const finalRr = param.rr;
+  const finalFiO2 = param.fio2;
+  const finalMve = parseFloat(((finalVte * finalRr) / 1000).toFixed(1));
+
+  // Write values to elements (checking for safety)
+  const pipEl = document.getElementById('ventPip');
+  const peepEl = document.getElementById('ventPeep');
+  const vteEl = document.getElementById('ventVte');
+  const mveEl = document.getElementById('ventMve');
+  const rrEl = document.getElementById('ventRr');
+  const fio2El = document.getElementById('ventFiO2');
+  const alarmEl = document.getElementById('ventAlarm');
+  const modeEl = document.getElementById('ventMode');
+
+  if (pipEl) pipEl.textContent = finalPip;
+  if (peepEl) peepEl.textContent = finalPeep;
+  if (vteEl) vteEl.textContent = finalVte;
+  if (mveEl) mveEl.textContent = finalMve.toFixed(1);
+  if (rrEl) rrEl.textContent = finalRr;
+  if (fio2El) fio2El.textContent = finalFiO2;
+
+  if (modeEl) modeEl.textContent = param.mode;
+
+  if (alarmEl) {
+    alarmEl.textContent = param.alarm;
+    if (param.alarmState === 'warning') {
+      alarmEl.className = 'vent-alarm warning';
+    } else {
+      alarmEl.className = 'vent-alarm normal';
+    }
+  }
+
+  // Render dials if forced or parameters changed
+  if (force || !ventAnim._lastDialScenario || ventAnim._lastDialScenario !== scenarioId || ventAnim._lastDialVt !== baseVt) {
+    renderVentilatorDials(param, baseVt);
+    ventAnim._lastDialScenario = scenarioId;
+    ventAnim._lastDialVt = baseVt;
+  }
+}
+
+function samplePathData(pathString, baselineY) {
+  const svg = document.getElementById('waveformSvg');
+  if (!svg) return new Array(400).fill(baselineY);
+  
+  const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
+  path.setAttribute('d', pathString);
+  svg.appendChild(path);
+  
+  let totalLength = 0;
+  try {
+    totalLength = path.getTotalLength();
+  } catch (e) {
+    totalLength = 400;
+  }
+  
+  const pathPoints = [];
+  const numSamples = Math.max(1000, Math.round(totalLength * 3));
+  for (let i = 0; i <= numSamples; i++) {
+    const len = (i / numSamples) * totalLength;
+    try {
+      pathPoints.push(path.getPointAtLength(len));
+    } catch (e) {
+      // ignore
+    }
+  }
+  
+  const result = new Array(400).fill(baselineY);
+  for (let x = 0; x < 400; x++) {
+    let closestPt = null;
+    let minDist = Infinity;
+    for (let i = 0; i < pathPoints.length; i++) {
+      const dist = Math.abs(pathPoints[i].x - x);
+      if (dist < minDist) {
+        minDist = dist;
+        closestPt = pathPoints[i];
+      }
+    }
+    if (closestPt && minDist < 6) {
+      result[x] = closestPt.y;
+    } else {
+      result[x] = baselineY;
+    }
+  }
